## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# NuGet
*.nupkg
*.snupkg
.nuget/
project.lock.json
project.assets.json

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# VS Code dir
.vscode/

# Rider
rider/
.idea_modules/

# Python Tools for Visual Studio
__pycache__/
*.py[cod]

# Cake
*.cake

# dotCover
.dotCover

# Node
node_modules/

# OS files
Thumbs.db
.DS_Store

# User Files
*.log
*.local
*.private

# Build output by configuration
/bin/
/obj/
/packages/

# NuGet Restore
.msbuild.log

# Custom
*.bak
*.tmp
~*